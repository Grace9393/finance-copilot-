{
  "version": 2,
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "api/*.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/chat/status", "dest": "/api/chat.ts" },
    { "src": "/api/dashboard/options", "dest": "/api/dashboard.ts" },
    { "src": "/api/dashboard",   "dest": "/api/dashboard.ts" },
    { "src": "/api/health",      "dest": "/api/health.ts" },
    { "src": "/api/analyse",     "dest": "/api/analyse.ts" },
    { "src": "/api/upload",      "dest": "/api/upload.ts" },
    { "src": "/api/chat",        "dest": "/api/chat.ts" },
    { "src": "/(.*)",            "dest": "/client/$1" }
  ]
}
