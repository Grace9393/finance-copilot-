{
  "version": 2,
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "api-dist/*.mjs",
      "use": "@vercel/node",
      "config": { "maxDuration": 60, "includeFiles": "api-dist/pdf.worker.mjs" }
    }
  ],
  "routes": [
    { "src": "/api/chat/status", "dest": "/api-dist/chat.mjs" },
    { "src": "/api/dashboard/options", "dest": "/api-dist/dashboard.mjs" },
    { "src": "/api/dashboard",   "dest": "/api-dist/dashboard.mjs" },
    { "src": "/api/health",      "dest": "/api-dist/health.mjs" },
    { "src": "/api/analyse",     "dest": "/api-dist/analyse.mjs" },
    { "src": "/api/upload",      "dest": "/api-dist/upload.mjs" },
    { "src": "/api/source",      "dest": "/api-dist/source.mjs" },
    { "src": "/api/pptx",        "dest": "/api-dist/pptx.mjs" },
    { "src": "/api/chat",        "dest": "/api-dist/chat.mjs" },
    { "src": "/(.*)",            "dest": "/client/$1" }
  ]
}
